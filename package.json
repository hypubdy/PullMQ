{
  "name": "@hypubdy/pullmq",
  "version": "1.1.0",
  "description": "Redis-based message queue with BullMQ Pro-compatible API and group scheduling",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx examples/bench.ts",
    "stress": "tsx examples/05-stress.ts",
    "soak": "tsx examples/06-soak-kill.ts",
    "ex:pro-groups": "tsx examples/07-pro-groups.ts",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "queue",
    "redis",
    "bullmq",
    "jobs",
    "worker",
    "group",
    "rate-limit"
  ],
  "author": "hypubdy",
  "license": "MIT",
  "peerDependencies": {
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ioredis": "^5.11.1",
    "tsup": "^8.3.5",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
